# Phalo Transportation — environment template.
# Copy this file to `.env.local` and fill in REAL values. `.env.local` is gitignored;
# this template is committed so the whole team knows exactly what to configure.

# --- Supabase (required) ---
# Project Settings -> API. The publishable/anon key is public by design (RLS protects data).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_SUPABASE_URL=https://mjrjvvsvgtseyvrfmzfy.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_W9TYoir3qg2iiJGprHTvyQ_IL8RadB_

# --- Email via Resend (transactional) ---
# Sign up at https://resend.com → grab the API key.
# IMPORTANT: until you verify your sending domain at Resend (Settings -> Domains),
# you can ONLY send to the email address of your Resend account owner.
# Once verified, set BOOKING_FROM_EMAIL to a "Display Name <address@yourdomain.com>"
# whose domain is verified at Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
BOOKING_FROM_EMAIL=Phalo Transportation <bookings@phalotrans.com>
SITE_URL=https://phalotrans.com

# --- Google Maps (required for booking distance + autocomplete) ---
# Google Cloud Console -> enable Distance Matrix API + Places API.
# Restrict the key to those two APIs and your domain referer.
GOOGLE_MAPS_API_KEY=AIza...

# --- Management notifications for chat escalations (optional) ---
# The DB queue (support_requests) always records escalations; these just add a push.
# PREFERRED: Telegram — free + instant, no API quota or domain setup (via @BotFather):
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
# Fallback only (uses the same Resend setup above):
# MANAGEMENT_EMAIL=ops@phalotrans.com

# --- Stripe payments (10% deposit at booking + balance after the ride) ---
# Use TEST keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
# Webhook signing secret (from `stripe listen` locally, or the Dashboard webhook endpoint):
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
