# === Supabase ===
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side (Critical)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co/rest/v1/
# Service role / secret key (server-only). Newer Supabase dashboards label this SUPABASE_SECRET_KEY.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_SECRET_KEY=your_supabase_secret_key_sb_secret_

# === Stripe ===
# Use your own keys from Stripe Dashboard (Developers → API keys).
# Publishable key (starts with pk_...) goes to NEXT_PUBLIC_ — safe for browser.
# Secret key (starts with sk_...) is server-only.
# Webhook secret (whsec_...) is obtained after you register the endpoint URL.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51YourTestKeyHere
STRIPE_SECRET_KEY=sk_test_51YourTestSecretHere
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
# For live: replace with pk_live_... / sk_live_... and update webhook secret + endpoint URL.

# === Email (Resend) ===
RESEND_API_KEY=re_your_resend_api_key
#
# BEFORE your domain is verified in Resend:
#   RESEND_USE_SANDBOX_FROM=true
#   → Only your Resend account email can receive mail.
#
# AFTER phalotrans.com is verified in Resend, remove RESEND_USE_SANDBOX_FROM.
RESEND_USE_SANDBOX_FROM=true
#
# Customer booking emails — display name + bare address (confirmation, received, lifecycle)
BOOKING_FROM_NAME=Phalo Transportation Booking
BOOKING_FROM_ADDRESS=bookings@phalotrans.com
#
# Driver dispatch emails — display name + bare address
DISPATCH_FROM_NAME=Trip Dispatch - Phalo Transportation
DISPATCH_FROM_ADDRESS=no-reply@phalotrans.com
DISPATCH_REPLY_TO_EMAIL=info.phalotrans@gmail.com
#
# Deprecated (still supported): legacy combined From header
# BOOKING_FROM_EMAIL="Phalo Transportation Booking <bookings@phalotrans.com>"
# DISPATCH_FROM_EMAIL="Trip Dispatch - Phalo Transportation <no-reply@phalotrans.com>"

# === SMS (optional — driver dispatch) ===
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# === Other ===
# Server-side Google key (used by /api/places/autocomplete and /api/places/distance).
# Must have Places API and Distance Matrix API enabled. Use IP restrictions (or none) — do NOT use this key on client.
GOOGLE_MAPS_API_KEY=your_google_server_api_key
# (Legacy/unused) Previously loaded for client-side Places; autocomplete is now server-proxied so this is no longer required for booking.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
SITE_URL=https://vipodyssey.com

# --- Cloudflare / Wrangler specific (for `npm run preview` / wrangler dev) ---
# If testing the Cloudflare build locally (`npm run preview`), also create a sibling file
# named `.dev.vars` (gitignored) with the SAME server-only keys in simple KEY=VALUE form:
#   GOOGLE_MAPS_API_KEY=...
#   SUPABASE_SERVICE_ROLE_KEY=...
#   etc.
# .env.local is used by `npm run dev`; .dev.vars is used by wrangler for the Pages/Worker preview.