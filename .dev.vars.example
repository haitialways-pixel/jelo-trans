# .dev.vars.example
# Copy to .dev.vars (gitignored) when testing the Cloudflare build locally:
#   cp .dev.vars.example .dev.vars
#   # then edit .dev.vars with real values
#
# This file is loaded by `wrangler dev` (used by `npm run preview`).
# Format is simple KEY=VALUE per line (no "export", no surrounding quotes for most values).
#
# Server-only secrets (required for booking flow, emails, payments, etc.):
GOOGLE_MAPS_API_KEY=your_google_server_api_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_here
RESEND_API_KEY=your_resend_api_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
BOOKING_FROM_NAME=Imperial Odyssey Booking
BOOKING_FROM_ADDRESS=bookings@vipodyssey.com
DISPATCH_FROM_NAME=Trip Dispatch - Imperial Odyssey
DISPATCH_FROM_ADDRESS=no-reply@vipodyssey.com
DISPATCH_REPLY_TO_EMAIL=concierge@vipodyssey.com
MANAGEMENT_EMAIL=info.phalotrans@gmail.com
SITE_URL=https://vipodyssey.com

# Public ones (if your preview build needs them at runtime):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_here
